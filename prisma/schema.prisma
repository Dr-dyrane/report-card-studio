generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

enum AssessmentMode {
  CONTINUOUS_AND_EXAM
  EXAM_ONLY
}

model School {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  sessions   Session[]
  classrooms Classroom[]
  students   Student[]
  subjects   Subject[]
}

model Session {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(false)
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms     Term[]
}

model Term {
  id             String       @id @default(cuid())
  name           String
  sequence       Int
  isActive       Boolean      @default(false)
  sessionId      String
  nextTermBegins String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reportCards    ReportCard[]

  @@unique([sessionId, sequence])
}

model Classroom {
  id            String         @id @default(cuid())
  name          String
  level         String?
  teacherName   String?
  displayOrder  Int            @default(0)
  schoolId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students      Student[]
  classSubjects ClassSubject[]
  reportCards   ReportCard[]
}

model Student {
  id              String       @id @default(cuid())
  fullName        String
  admissionNumber String?
  gender          String?
  isActive        Boolean      @default(true)
  schoolId        String
  classroomId     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  school          School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classroom       Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  reportCards     ReportCard[]

  @@unique([classroomId, fullName])
}

model Subject {
  id             String         @id @default(cuid())
  name           String
  category       String?
  assessmentMode AssessmentMode
  a1Max          Int?
  a2Max          Int?
  examMax        Int?
  displayOrder   Int            @default(0)
  isActive       Boolean        @default(true)
  schoolId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classSubjects  ClassSubject[]
  reportScores   ReportScore[]

  @@unique([schoolId, name])
}

model ClassSubject {
  id           String    @id @default(cuid())
  classroomId  String
  subjectId    String
  displayOrder Int       @default(0)
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  subject      Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classroomId, subjectId])
}

model ReportCard {
  id                 String        @id @default(cuid())
  studentId          String
  classroomId        String
  termId             String
  status             ReportStatus  @default(DRAFT)
  position           String?
  classSize          Int?
  grandTotal         Int           @default(0)
  grandMax           Int           @default(1000)
  assessment1Total   Int           @default(0)
  assessment2Total   Int           @default(0)
  examTotal          Int           @default(0)
  teacherComment     String?
  headTeacherComment String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  student            Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom          Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  term               Term          @relation(fields: [termId], references: [id], onDelete: Cascade)
  scores             ReportScore[]

  @@unique([studentId, termId])
}

model ReportScore {
  id           String     @id @default(cuid())
  reportCardId String
  subjectId    String
  a1Score      Int?
  a2Score      Int?
  examScore    Int?
  totalScore   Int        @default(0)
  reportCard   ReportCard @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([reportCardId, subjectId])
}
